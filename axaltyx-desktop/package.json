
{
  "name": "axaltyx-desktop",
  "version": "1.0.0",
  "description": "AxaltyX - 专业统计分析软件",
  "copyright": "Copyright © 2024 TBJ114",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:electron && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && npm run build:electron && electron .\"",
    "electron:build": "vite build && npm run build:electron && electron-builder",
    "build:electron": "tsc -p tsconfig.electron.json"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.62.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "react-router-dom": "^6.22.0",
    "dayjs": "^1.11.10",
    "lucide-react": "^0.344.0",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "python-shell": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.tbj114.axaltyx",
    "productName": "AxaltyX",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
